meta {
  name: Register
  type: http
  seq: 2
}

post {
  url: {{base_url}}/auth/register
  body: json
  auth: none
}

body:json {
  {
    "name": "New User",
    "email": "newuser@example.com",
    "password": "password123"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("token", res.body.token);
  }
}
