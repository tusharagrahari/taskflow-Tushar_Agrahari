meta {
  name: Create Task
  type: http
  seq: 2
}

post {
  url: {{base_url}}/projects/{{project_id}}/tasks
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "title": "My New Task",
    "description": "Task description",
    "priority": "high",
    "due_date": "2026-05-01"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("task_id", res.body.id);
  }
}
