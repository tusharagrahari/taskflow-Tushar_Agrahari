# Database
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow_secret
POSTGRES_DB=taskflow

# Connection string for sqlx
# Local dev (API outside Docker): use localhost
DATABASE_URL=postgres://taskflow:taskflow_secret@localhost:5432/taskflow
# Inside Docker, docker-compose.yml overrides DATABASE_URL to use the db service hostname

JWT_SECRET=change-me-to-a-long-random-string-in-production

# Server
SERVER_PORT=8080
RUST_LOG=info
