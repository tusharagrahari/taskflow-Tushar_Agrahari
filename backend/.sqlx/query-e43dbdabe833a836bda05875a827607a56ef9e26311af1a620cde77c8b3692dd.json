  "query": "SELECT DISTINCT p.*\n           FROM projects p\n           LEFT JOIN tasks t ON t.project_id = p.id\n           WHERE p.owner_id = $1 OR t.assignee_id = $1\n           ORDER BY p.created_at DESC\n           LIMIT $2 OFFSET $3",
